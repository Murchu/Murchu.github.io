---
import logo from '../img/logos/logo.svg';
import logoAlt from '../img/logos/logoAlt.svg';
import smLogo from '../img/logos/SMlogo.svg';
import smLogoAlt from '../img/logos/SMlogoAlt.svg';

interface Props {
  gradient?: string;
}

const { gradient = 'none' } = Astro.props;
const isNone = !gradient || gradient === 'none';
const wrapperClass = isNone ? '' : `${gradient} z-10`;
const navClass = isNone ? 'text-slate-600' : 'text-slate-200';
const hoverClass = isNone ? 'hover:text-teal-700' : 'hover:text-white';
const logoMobile = isNone ? smLogo.src : smLogoAlt.src;
const logoDesktop = isNone ? logo.src : logoAlt.src;
---

<div class={wrapperClass}>
  <nav class="flex justify-between px-6 py-8 mx-auto sm:max-w-screen-xl sm:mx-auto bg-transparent">
    <a href="/" aria-label="Home">
      <div class="sm:hidden">
        <img class="h-6" src={logoMobile} alt="Colm Murphy logo" />
      </div>
      <div class="hidden sm:block">
        <img class="h-6" src={logoDesktop} alt="Colm Murphy logo" />
      </div>
    </a>

    <div class={`hidden font-normal space-x-8 lg:flex ${navClass}`}>
      <a class={hoverClass} href="/">Home</a>
      <a class={hoverClass} href="/src/Colm_Murphy_CV.pdf">About</a>
      <a class={hoverClass} href="/process">Process</a>
    </div>

    <div class="flex lg:hidden z-20">
      <details class="dropdown relative inline-block text-left">
        <summary class="inline-flex justify-center w-full px-4 py-2 text-sm font-medium leading-5 text-gray-700 transition duration-150 ease-in-out bg-white border border-gray-300 rounded-md cursor-pointer select-none">
          <span>More</span>
          <svg class="w-5 h-5 ml-2 -mr-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
          </svg>
        </summary>
        <div class="opacity-0 invisible dropdown-menu transition-all duration-300 transform origin-top-right -translate-y-2 scale-95 z-10">
          <div class="absolute right-0 w-56 mt-2 origin-top-right bg-white border border-gray-200 divide-y divide-gray-100 rounded-md shadow-lg outline-none">
            <a href="/" class="block px-4 py-3 text-sm leading-5 text-gray-700 hover:bg-gray-50">Home</a>
            <a href="/src/Colm_Murphy_CV.pdf" class="block px-4 py-3 text-sm leading-5 text-gray-700 hover:bg-gray-50">About</a>
            <a href="/process" class="block px-4 py-3 text-sm leading-5 text-gray-700 hover:bg-gray-50">Process</a>
          </div>
        </div>
      </details>
    </div>
  </nav>
</div>
