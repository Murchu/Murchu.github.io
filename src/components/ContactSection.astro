---
interface SocialLink {
  label: string;
  href?: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  intro?: string;
  location?: string;
  displayEmail?: string;
  emailAddress?: string;
  subject?: string;
  socialLinks?: SocialLink[];
}

const {
  eyebrow = 'Contact',
  title = 'If the brief is complex, that is usually where I do my best work.',
  intro = 'Email is the cleanest way to start. The other channels are placeholders for now, but the section is ready for them when you are.',
  location = 'Cork, Ireland',
  displayEmail = 'colmmurchu[in]gmail[plop]com',
  emailAddress = 'colmmurchu@gmail.com',
  subject = 'Hello friend!',
  socialLinks = [
    { label: 'LinkedIn' },
    { label: 'Instagram' },
    { label: 'YouTube' },
  ],
} = Astro.props;

const mailtoHref = `mailto:${emailAddress}?subject=${encodeURIComponent(subject)}`;

const iconPaths: Record<string, string> = {
  LinkedIn: 'M8.25 8.25h3.43V19.5H8.25V8.25ZM10 3.75a1.99 1.99 0 1 0 0 3.98 1.99 1.99 0 0 0 0-3.98ZM14.25 8.25h3.29v1.54h.05c.46-.87 1.58-1.79 3.24-1.79 3.47 0 4.11 2.28 4.11 5.24v6.26h-3.43v-5.55c0-1.32-.02-3.02-1.84-3.02-1.84 0-2.12 1.44-2.12 2.92v5.65h-3.3V8.25Z',
  Instagram: 'M12 7.03c1.62 0 1.81.01 2.45.04 1.67.08 2.45.87 2.53 2.53.03.64.04.83.04 2.45s-.01 1.81-.04 2.45c-.08 1.67-.87 2.45-2.53 2.53-.64.03-.83.04-2.45.04s-1.81-.01-2.45-.04c-1.67-.08-2.45-.87-2.53-2.53C7 13.86 7 13.67 7 12.05s0-1.81.04-2.45c.08-1.67.87-2.45 2.53-2.53.64-.03.83-.04 2.43-.04Zm0-2.03c-1.67 0-1.88.01-2.54.04-2.7.12-4.33 1.75-4.45 4.45-.03.66-.04.87-.04 2.54 0 1.67.01 1.88.04 2.54.12 2.69 1.75 4.33 4.45 4.45.66.03.87.04 2.54.04 1.67 0 1.88-.01 2.54-.04 2.69-.12 4.33-1.76 4.45-4.45.03-.66.04-.87.04-2.54 0-1.67-.01-1.88-.04-2.54-.12-2.69-1.76-4.33-4.45-4.45-.66-.03-.87-.04-2.54-.04Zm0 5.49A3.56 3.56 0 1 0 12 17.6a3.56 3.56 0 0 0 0-7.11Zm0 5.08A1.53 1.53 0 1 1 12 12.5a1.53 1.53 0 0 1 0 3.07Zm4.53-5.31a.83.83 0 1 1-1.66 0 .83.83 0 0 1 1.66 0Z',
  YouTube: 'M19.81 8.72a2.5 2.5 0 0 0-1.76-1.77C16.5 6.5 12 6.5 12 6.5s-4.5 0-6.05.45a2.5 2.5 0 0 0-1.76 1.77A26.1 26.1 0 0 0 3.75 12a26.1 26.1 0 0 0 .44 3.28 2.5 2.5 0 0 0 1.76 1.77c1.55.45 6.05.45 6.05.45s4.5 0 6.05-.45a2.5 2.5 0 0 0 1.76-1.77c.29-1.08.44-2.18.44-3.28 0-1.1-.15-2.2-.44-3.28ZM10.5 14.77V9.23L15.27 12 10.5 14.77Z',
};
---

<section class="px-6 pt-14 pb-24 sm:pt-20 sm:pb-28">
  <div class="mx-auto max-w-screen-xl overflow-hidden rounded-md border border-stone-200/80 bg-[radial-gradient(circle_at_top_left,_rgba(125,211,252,0.22),_transparent_34%),linear-gradient(135deg,_rgba(255,255,255,0.98),_rgba(248,250,252,0.95)_52%,_rgba(254,249,195,0.85))] md:rounded-xl">
    <div class="grid gap-12 px-6 py-8 sm:px-10 sm:py-10 lg:grid-cols-[minmax(0,1.35fr)_minmax(18rem,0.85fr)] lg:px-14 lg:py-14">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.35em] text-cyan-700/80">{eyebrow}</p>
        <h2 class="mt-5 max-w-xl font-bold text-3xl leading-tight text-slate-900 sm:text-4xl lg:text-[3.1rem] lg:leading-[1.05]">
          {title}
        </h2>
        <p class="mt-6 max-w-2xl text-base leading-8 text-slate-600 sm:text-lg sm:leading-8">
          {intro}
        </p>
      </div>

      <div class="relative">
        <div class="absolute inset-x-10 top-0 h-20 rounded-full bg-cyan-200/40 blur-3xl"></div>
        <div class="relative rounded-[1.75rem] border border-white/70 bg-white/85 p-6 shadow-[0_24px_60px_-36px_rgba(15,23,42,0.42)] backdrop-blur sm:p-7">
          <div class="grid gap-6">
            <div>
              <p class="text-[0.68rem] font-semibold uppercase tracking-[0.32em] text-slate-400">Location</p>
              <div class="mt-2 inline-flex items-center gap-3 rounded-full border border-emerald-100 bg-white/75 px-4 py-2 text-lg font-medium text-slate-800">
                <span class="text-xl leading-none" aria-hidden="true">🇮🇪</span>
                <span>{location}</span>
              </div>
            </div>

            <div>
              <p class="text-[0.68rem] font-semibold uppercase tracking-[0.32em] text-slate-400">Email</p>
              <a
                href={mailtoHref}
                aria-label="Email Colm Murphy"
                class="group mt-2 inline-flex items-center gap-3 rounded-full border border-cyan-200 bg-cyan-50 px-4 py-3 text-sm font-semibold text-cyan-900 transition duration-300 hover:-translate-y-0.5 hover:border-cyan-300 hover:bg-cyan-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400 focus-visible:ring-offset-2"
              >
                <span class="grid h-9 w-9 place-items-center rounded-full bg-cyan-600 text-white shadow-sm transition duration-300 group-hover:bg-cyan-700">
                  <svg class="h-4 w-4 fill-current" viewBox="0 0 36 36" aria-hidden="true">
                    <path d="M10,10H10c-1.1,0-1.99,0.9-1.99,2L8,24c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V12C28,10.9,27.1,10,26,10z M10,24H10V14l8,5l8-5V24z M18,17l-8-5h16L18,17z" />
                  </svg>
                </span>
                <span class="break-all text-left sm:break-normal">{displayEmail}</span>
              </a>
            </div>

            <div>
              <p class="text-[0.68rem] font-semibold uppercase tracking-[0.32em] text-slate-400">Elsewhere</p>
              <div class="mt-3 flex flex-wrap gap-3">
                {socialLinks.map((link) => {
                  const iconPath = iconPaths[link.label];

                  if (link.href) {
                    return (
                      <a
                        href={link.href}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex items-center gap-2 rounded-full border border-stone-200 bg-stone-50 px-4 py-2.5 text-sm font-medium text-slate-700 transition duration-300 hover:-translate-y-0.5 hover:border-stone-300 hover:bg-white"
                      >
                        {iconPath && (
                          <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                            <path d={iconPath} />
                          </svg>
                        )}
                        <span>{link.label}</span>
                      </a>
                    );
                  }

                  return (
                    <span class="inline-flex items-center gap-2 rounded-full border border-dashed border-stone-300 bg-stone-50/80 px-4 py-2.5 text-sm font-medium text-slate-500">
                      {iconPath && (
                        <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                          <path d={iconPath} />
                        </svg>
                      )}
                      <span>{link.label}</span>
                    </span>
                  );
                })}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>