---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureTile from '../components/FeatureTile.astro';
import SiteHeader from '../components/SiteHeader.astro';
import enterpriseCard from '../img/index/ET.png';
import nativeCard from '../img/index/NA.png';
import processCard from '../img/index/PD.png';
import circularOrnament from '../img/CaseStudy/CircularOrnament45.svg';
---

<BaseLayout
  title="Colm Murphy | Home"
  description="Portfolio of Colm Murphy, a Product Designer and AI Engineer with 10 years of experience shaping accessible enterprise software and practical AI-enabled products."
  image={enterpriseCard.src}
  imageAlt="Preview of Colm Murphy's enterprise product design work"
>
  <SiteHeader gradient="none" />

  <main class="mt-4 font-light text-stone-700 leading-loose sm:max-w-screen-xl sm:mx-auto">
    <header class="px-6 py-4">
      <h1 class="font-bold text-3xl sm:text-4xl">
        Hello, <span class="p-2 bg-cyan-50 hover:bg-red-50 transition-colors duration-300">I am Colm Murphy,</span>
      </h1>

      <p class="mt-6 w-full font-extralight sm:text-xl sm:leading-loose">
        I am a <span class="font-medium text-cyan-600">Product Designer &amp; AI Engineer</span> with 10 years of experience shaping how software works and feels. I specialize in turning complex enterprise strategy into functional, accessible products using AI engineering to solve real problems rather than just following trends.
      </p>
    </header>

    <div class="px-6 hidden lg:block text-3xl">
      <div class="grid grid-cols-2 gap-8 mt-10">
        <FeatureTile
          href="/et"
          badgeLabel="Case Study"
          badgeIcon="briefcase"
          title="Enterprise"
          titleAccent="Design"
          description="Research, systems thinking, and enterprise product delivery."
          theme="enterprise"
          asset={circularOrnament}
        />

        <FeatureTile
          href="/native"
          badgeLabel="Mobile Product"
          badgeIcon="device-phone"
          title="Native App"
          titleAccent="Design"
          description="Mobile UX, flows, and design systems for native product experiences."
          theme="native"
          asset={circularOrnament}
        />
      </div>

      <div class="grid grid-cols-2 gap-8 mt-10">
        <FeatureTile
          href="/process"
          badgeLabel="Framework"
          badgeIcon="squares"
          title="Process"
          titleAccent="Design"
          description="Discovery, testing, and delivery methods for product teams."
          theme="process"
          asset={circularOrnament}
        />

        <FeatureTile
          href="/case-study"
          badgeLabel="Research"
          title="Case"
          titleAccent="Study"
          description="A focused UX research story from insight through concept validation."
          theme="case-study-warm"
          asset={circularOrnament}
          badgeIcon="search"
        />
      </div>
    </div>

    <div class="gap-8 lg:hidden columns-1 ml-6 mr-6">
      <div class="mb-6">
        <FeatureTile
          href="/et"
          badgeLabel="Case Study"
          badgeIcon="briefcase"
          title="Enterprise"
          titleAccent="Design"
          description="Research, systems thinking, and enterprise product delivery."
          theme="enterprise"
          asset={circularOrnament}
        />
      </div>

      <div class="mb-6">
        <FeatureTile
          href="/native"
          badgeLabel="Mobile Product"
          badgeIcon="device-phone"
          title="Native App"
          titleAccent="Design"
          description="Mobile UX, flows, and design systems for native product experiences."
          theme="native"
          asset={circularOrnament}
        />
      </div>

      <div class="mb-6">
        <FeatureTile
          href="/process"
          badgeLabel="Framework"
          badgeIcon="squares"
          title="Process"
          titleAccent="Design"
          description="Discovery, testing, and delivery methods for product teams."
          theme="process"
          asset={circularOrnament}
        />
      </div>

      <div class="mb-6">
        <FeatureTile
          href="/case-study"
          badgeLabel="Research"
          title="Case"
          titleAccent="Study"
          description="A focused UX research story from insight through concept validation."
          theme="case-study-warm"
          asset={circularOrnament}
          badgeIcon="search"
        />
      </div>
    </div>

    <div class="px-6 py-32 grid place-items-center">
      <a href="mailto:colmmurchu@gmail.com?subject=Hello friend!" aria-label="Email Colm Murphy">
        <svg class="mailTo text-white fill-current h-10 w-10 rounded-full" viewBox="0 0 36 36" aria-hidden="true">
          <path d="M10,10H10c-1.1,0-1.99,0.9-1.99,2L8,24c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V12C28,10.9,27.1,10,26,10z M10,24H10V14l8,5l8-5V24z M18,17l-8-5h16L18,17z" />
        </svg>
      </a>
    </div>
  </main>
</BaseLayout>
