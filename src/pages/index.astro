---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import enterpriseCard from '../img/index/ET.png';
import nativeCard from '../img/index/NA.png';
import processCard from '../img/index/PD.png';
import caseStudyCard from '../img/index/CS.png';
---

<BaseLayout
  title="Colm Murphy | Home"
  description="Portfolio of Colm Murphy, a Product Designer and AI Engineer with 10 years of experience shaping accessible enterprise software and practical AI-enabled products."
  image={enterpriseCard.src}
  imageAlt="Preview of Colm Murphy's enterprise product design work"
>
  <SiteHeader gradient="none" />

  <main class="mt-4 font-light text-stone-700 leading-loose sm:max-w-screen-xl sm:mx-auto">
    <header class="px-6 py-4">
      <h1 class="font-bold text-3xl sm:text-4xl">
        Hello, <span class="p-2 bg-cyan-50 hover:bg-red-50 transition-colors duration-300">I am Colm Murphy,</span>
      </h1>

      <p class="mt-6 w-full font-extralight sm:text-xl sm:leading-loose">
        I am a <span class="font-medium text-cyan-600">Product Designer &amp; AI Engineer</span> with 10 years of experience shaping how software works and feels. I specialize in turning complex enterprise strategy into functional, accessible products using AI engineering to solve real problems rather than just following trends.
      </p>
    </header>

    <div class="px-6 hidden md:block text-3xl">
      <div class="columns-2 gap-8 mt-10">
        <div>
          <a href="/et">
            <div class="relative overflow-clip bg-red-50 rounded-xl">
              <Image class="w-full" src={enterpriseCard} alt="Enterprise product design preview" loading="lazy" sizes="(min-width: 768px) 50vw, 100vw" />
              <div class="absolute p-20 text-opacity-25 hover:text-opacity-100 duration-300 inset-0 z-10 flex justify-center items-end text-stone-500">
                Enterprise<span class="font-semibold">&nbsp;Design</span>
              </div>
            </div>
          </a>
        </div>

        <div>
          <a href="/native">
            <div class="relative overflow-clip bg-amber-50 rounded-xl">
              <Image class="w-full" src={nativeCard} alt="Native app design preview" loading="lazy" sizes="(min-width: 768px) 50vw, 100vw" />
              <div class="absolute p-20 text-opacity-25 hover:text-opacity-100 duration-300 inset-0 z-10 flex justify-center items-end text-stone-500">
                Native App<span class="font-semibold">&nbsp;Design</span>
              </div>
            </div>
          </a>
        </div>
      </div>

      <div class="gap-8 columns-2 mt-10">
        <div>
          <a href="/process">
            <div class="relative overflow-clip bg-indigo-50 rounded-xl">
              <Image class="w-full" src={processCard} alt="Product design process preview" loading="lazy" sizes="(min-width: 768px) 50vw, 100vw" />
              <div class="absolute p-20 text-opacity-25 hover:text-opacity-100 duration-300 inset-0 z-10 flex justify-center items-end text-stone-500">
                Process<span class="font-semibold">&nbsp;Design</span>
              </div>
            </div>
          </a>
        </div>

        <div>
          <a href="/case-study">
            <div class="relative overflow-clip bg-emerald-50 rounded-xl">
              <Image class="w-full" src={caseStudyCard} alt="Payslip case study preview" loading="lazy" sizes="(min-width: 768px) 50vw, 100vw" />
              <div class="absolute p-20 text-opacity-25 hover:text-opacity-100 duration-300 inset-0 z-10 flex justify-center items-end text-stone-500">
                Case<span class="font-semibold">&nbsp;Study</span>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>

    <div class="gap-8 md:hidden columns-1 ml-6 mr-6">
      <a href="/et">
        <div class="mb-6 relative overflow-hidden bg-red-50 rounded-md">
          <Image class="w-full" src={enterpriseCard} alt="Enterprise product design preview" loading="lazy" sizes="100vw" />
          <div class="absolute p-10 text-opacity-75 hover:text-opacity-100 duration-300 inset-0 z-10 flex justify-center items-end text-stone-500">
            Enterprise<span class="font-semibold">&nbsp;Design</span>
          </div>
        </div>
      </a>

      <a href="/native">
        <div class="mb-6 relative overflow-hidden bg-amber-50 rounded-md">
          <Image class="w-full" src={nativeCard} alt="Native app design preview" loading="lazy" sizes="100vw" />
          <div class="absolute p-10 text-opacity-75 hover:text-opacity-100 duration-300 inset-0 z-10 flex justify-center items-end text-stone-500">
            Native App <span class="font-semibold">&nbsp;Design</span>
          </div>
        </div>
      </a>

      <a href="/process">
        <div class="mb-6 relative overflow-hidden bg-indigo-50 rounded-md">
          <Image class="w-full" src={processCard} alt="Product design process preview" loading="lazy" sizes="100vw" />
          <div class="absolute p-10 text-opacity-75 hover:text-opacity-100 duration-300 inset-0 z-10 flex justify-center items-end text-stone-500">
            Process<span class="font-semibold">&nbsp;Design</span>
          </div>
        </div>
      </a>

      <a href="/case-study">
        <div class="mb-6 relative overflow-hidden bg-emerald-50 rounded-md">
          <Image class="w-full" src={caseStudyCard} alt="Payslip case study preview" loading="lazy" sizes="100vw" />
          <div class="absolute p-10 text-opacity-75 hover:text-opacity-100 duration-300 inset-0 z-10 flex justify-center items-end text-stone-500">
            Case<span class="font-semibold">&nbsp;Study</span>
          </div>
        </div>
      </a>
    </div>

    <div class="px-6 py-32 grid place-items-center">
      <a href="mailto:colmmurchu@gmail.com?subject=Hello friend!" aria-label="Email Colm Murphy">
        <svg class="mailTo text-white fill-current h-10 w-10 rounded-full" viewBox="0 0 36 36" aria-hidden="true">
          <path d="M10,10H10c-1.1,0-1.99,0.9-1.99,2L8,24c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V12C28,10.9,27.1,10,26,10z M10,24H10V14l8,5l8-5V24z M18,17l-8-5h16L18,17z" />
        </svg>
      </a>
    </div>
  </main>
</BaseLayout>
